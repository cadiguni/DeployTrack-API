@DeployTrack.Api_HostAddress = http://localhost:5020
@Token = paste-token-here

POST {{DeployTrack.Api_HostAddress}}/api/auth/register
Content-Type: application/json

{
  "name": "Admin",
  "email": "admin@deploytrack.local",
  "password": "ChangeMe123",
  "role": "Admin"
}

###

POST {{DeployTrack.Api_HostAddress}}/api/auth/login
Content-Type: application/json

{
  "email": "admin@deploytrack.local",
  "password": "ChangeMe123"
}

###

GET {{DeployTrack.Api_HostAddress}}/api/environments
Authorization: Bearer {{Token}}
Accept: application/json

###

POST {{DeployTrack.Api_HostAddress}}/api/applications
Authorization: Bearer {{Token}}
Content-Type: application/json

{
  "name": "orders-api",
  "description": "Sample Orders API",
  "repositoryUrl": "https://github.com/user/orders-api"
}

###

POST {{DeployTrack.Api_HostAddress}}/api/deployments
Authorization: Bearer {{Token}}
Content-Type: application/json

{
  "applicationName": "orders-api",
  "environment": "production",
  "version": "1.0.0",
  "status": "Success",
  "deployedBy": "github-actions",
  "commitSha": "a1b2c3d",
  "pipelineUrl": "https://github.com/user/repo/actions/runs/123",
  "startedAt": "2026-05-18T20:10:00Z",
  "finishedAt": "2026-05-18T20:14:00Z"
}

###

GET {{DeployTrack.Api_HostAddress}}/api/deployments/latest?applicationName=orders-api&environment=production
Authorization: Bearer {{Token}}
Accept: application/json
